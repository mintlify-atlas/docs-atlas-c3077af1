  "keyFeatures": [
    "Background location tracking with configurable presets (continuous, responsive, efficient)",
    "Geofencing with entry, exit, and dwell events",
    "Trip tracking with ETA calculations and destination monitoring",
    "Location verification with fraud detection",
    "Beacon monitoring for proximity-based experiences",
    "Forward and reverse geocoding",
    "Place and geofence search",
    "Distance and route calculations",
    "Context API for comprehensive location intelligence",
    "In-app messaging based on location triggers",
    "Anonymous tracking mode for privacy compliance",
    "Indoor positioning support",
    "Motion activity detection"
  ],
